{
  "manifest_version": 3,
  "name": "VuliTab",
  "version": "1.0.1",
  "description": "VuliTab — the VuliStudy study buddy, in your browser. Log in, keep your focus timer in sync with the app, draw on any page, and stay on task.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "https://studybuddy-r616.onrender.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-focus.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
